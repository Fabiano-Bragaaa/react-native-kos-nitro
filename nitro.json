{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "kosnitro"
  ],
  "ios": {
    "iosModuleName": "KosNitro"
  },
  "android": {
    "androidNamespace": [
      "kosnitro"
    ],
    "androidCxxLibName": "KosNitro"
  },
  "autolinking": {
    "KosNitro": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridKosNitro"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}